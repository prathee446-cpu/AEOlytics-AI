generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  articles     Article[]
  chatSessions ChatSession[]
}

model Article {
  id              String                @id @default(uuid())
  title           String
  content         String
  status          ArticleStatus         @default(DRAFT)
  category        String                @default("General")
  tags            String[]
  aiScore         Float                 @default(0.0)
  visibilityScore Float                 @default(0.0)
  confidenceScore Float                 @default(0.0)
  suggestions     Json                  @default("[]")
  gapAnalysis     Json                  @default("{}")
  recommendations Json                  @default("[]")
  embedding       Float[]
  userId          String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  auditScores     Json                  @default("{}")
  author          String?
  canonicalUrl    String?
  entities        Json                  @default("[]")
  importedAt      DateTime?
  language        String?               @default("en")
  metaDescription String?
  ogTags          Json                  @default("{}")
  optimizerData   Json                  @default("{}")
  publishDate     String?
  readingTime     Int?
  schemas         Json                  @default("[]")
  sourceDomain    String?
  sourceUrl       String?
  wordCount       Int?
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSessions    ChatSession[]
  optimizations   OptimizationHistory[]
}

model ChatSession {
  id        String        @id @default(uuid())
  title     String
  userId    String
  articleId String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  article   Article?      @relation(fields: [articleId], references: [id])
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model OptimizationHistory {
  id               String   @id @default(uuid())
  articleId        String
  action           String
  previousContent  String
  optimizedContent String
  createdAt        DateTime @default(now())
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model VisibilityScan {
  id                String            @id @default(uuid())
  userId            String
  url               String
  domain            String
  visibilityScore   Float             @default(0.0)
  totalQueries      Int               @default(0)
  mentionCount      Int               @default(0)
  mentionPercent    Float             @default(0.0)
  competitorDomains String[]
  topCompetitors    Json              @default("[]")
  avgPosition       Float?
  scannedAt         DateTime          @default(now())
  queries           VisibilityQuery[]
}

model VisibilityQuery {
  id                 String         @id @default(uuid())
  scanId             String
  query              String
  llmResponse        String
  mentioned          Boolean        @default(false)
  mentionPosition    Int?
  competitorMentions Json           @default("[]")
  queryScore         Float          @default(0.0)
  createdAt          DateTime       @default(now())
  scan               VisibilityScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model RadarSession {
  id                String                @id @default(uuid())
  userId            String
  url               String
  domain            String
  engines           String[]
  trackedQueries    String[]
  competitorDomains String[]
  overallScore      Float                 @default(0.0)
  totalChecks       Int                   @default(0)
  totalMentions     Int                   @default(0)
  scannedAt         DateTime              @default(now())
  results           RadarQueryResult[]
  recommendations   RadarRecommendation[]
}

model RadarQueryResult {
  id                 String       @id @default(uuid())
  sessionId          String
  query              String
  engine             String
  mentioned          Boolean      @default(false)
  rankPosition       Int?
  citationStatus     String       @default("none")
  competitorMentions Json         @default("[]")
  responseExcerpt    String
  queryScore         Float        @default(0.0)
  createdAt          DateTime     @default(now())
  session            RadarSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model RadarRecommendation {
  id          String       @id @default(uuid())
  sessionId   String
  type        String
  priority    String       @default("medium")
  engine      String?
  title       String
  description String
  createdAt   DateTime     @default(now())
  session     RadarSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model AIActivity {
  id        String   @id @default(uuid())
  type      String
  message   String
  details   Json?    @default("{}")
  createdAt DateTime @default(now())
}

model VisibilityCompare {
  id              String   @id @default(uuid())
  userId          String
  url1            String
  url2            String
  domain1         String
  domain2         String
  winnerSummary   Json
  metrics         Json
  gapAnalysis     Json
  recommendations Json
  crawledAt       DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
